# Bruno Bock kiosk configuration
# Copy to `.env.local` (or let scripts/install.ps1 generate it).

# Unique identifier for this kiosk (e.g. kiosk-east-gate)
KIOSK_ID=kiosk-1
KIOSK_NAME="Kiosk 1"

# Comma-separated list of peer kiosk URLs on the LAN.
# Leave empty if this is the only kiosk.
# Example: http://10.0.0.21:3000,http://10.0.0.22:3000
LEADER_DISCOVERY=

# argon2-hashed admin PIN. Use scripts/hash-pin.ts or install.ps1.
# This bootstrap value is only used on first migration.
ADMIN_PIN_HASH=

# Local data paths
DB_PATH=./data/db.sqlite
MEDIA_PATH=./data/media

# Server bind
PORT=3000
HOSTNAME=0.0.0.0

# Logging
LOG_LEVEL=info
LOG_DIR=./data/logs

{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/media/[id]/[kind]",
      "regex": "^/api/media/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPkind": "nxtPkind"
      },
      "namedRegex": "^/api/media/(?<nxtPid>[^/]+?)/(?<nxtPkind>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/audit",
      "regex": "^/admin/audit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/audit(?:/)?$"
    },
    {
      "page": "/admin/employees",
      "regex": "^/admin/employees(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/employees(?:/)?$"
    },
    {
      "page": "/admin/kiosks",
      "regex": "^/admin/kiosks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/kiosks(?:/)?$"
    },
    {
      "page": "/admin/muster",
      "regex": "^/admin/muster(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/muster(?:/)?$"
    },
    {
      "page": "/admin/pin",
      "regex": "^/admin/pin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/pin(?:/)?$"
    },
    {
      "page": "/admin/settings",
      "regex": "^/admin/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/settings(?:/)?$"
    },
    {
      "page": "/admin/visitors",
      "regex": "^/admin/visitors(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/visitors(?:/)?$"
    },
    {
      "page": "/visitor",
      "regex": "^/visitor(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/visitor(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}